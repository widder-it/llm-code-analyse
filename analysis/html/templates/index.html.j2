{% extends "base.html.j2" %}

{% block title %}OFBiz Architekturdokumentation — Modulübersicht{% endblock %}

{% block content %}
<div class="page-header">
  <h1><i class="bi bi-diagram-3 me-2 text-primary"></i>Apache OFBiz — Modulübersicht</h1>
  <p class="text-muted mb-0 mt-1">Statische Code-Analyse · {{ modules | length }} Module dokumentiert</p>
</div>

<div class="content-area">
  <div class="row g-3">
    {% for mod in modules %}
    <div class="col-md-6 col-xl-4">
      <a href="{{ mod.id }}/index.html" class="text-decoration-none">
        <div class="class-card card h-100 p-3">
          <div class="d-flex align-items-center mb-2">
            <i class="bi bi-box text-primary me-2 fs-5"></i>
            <span class="fw-semibold fs-5">{{ mod.name }}</span>
          </div>
          <p class="text-muted small mb-3" style="min-height:3em">{{ mod.overview[:160] }}{% if mod.overview|length > 160 %}…{% endif %}</p>
          <div class="d-flex gap-2 mt-auto">
            <span class="stat-pill"><i class="bi bi-layers me-1"></i>{{ mod.stats.classes }} Klassen</span>
            <span class="stat-pill"><i class="bi bi-lightning me-1"></i>{{ mod.stats.methods }} Methoden</span>
          </div>
        </div>
      </a>
    </div>
    {% endfor %}
  </div>
</div>
{% endblock %}
