{% extends "base.html.j2" %}
{% block title %}KRITIS-Sicherheitsbewertung{% endblock %}

{% block content %}
<div class="page-header">
  <nav aria-label="breadcrumb">
    <ol class="breadcrumb mb-2">
      <li class="breadcrumb-item"><a href="{{ root }}index.html">Übersicht</a></li>
      <li class="breadcrumb-item active">KRITIS-Sicherheitsbewertung</li>
    </ol>
  </nav>
  <h1><i class="bi bi-shield-exclamation me-2 text-danger"></i>KRITIS-Sicherheitsbewertung</h1>
  <p class="text-muted mb-2 mt-1 small">
    Bewertungsstufe: <strong class="text-danger">{{ kritis.stufe }}</strong> &middot;
    Analyse: {{ kritis.analyse_datum }} &middot;
    Grundlage: IT-SiG 2.0, NIS2, BSI TR-02102, BSI TR-03183
  </p>
  <div class="d-flex gap-2 flex-wrap">
    <span class="stat-pill" style="background:#fee2e2;color:#991b1b">
      <i class="bi bi-exclamation-octagon-fill me-1"></i>{{ kritis.sofort | length }} CRITICAL — Sofortmaßnahme
    </span>
    <span class="stat-pill" style="background:#fef3c7;color:#92400e">
      <i class="bi bi-exclamation-triangle-fill me-1"></i>{{ kritis.kurzfristig | length }} HIGH — Kurzfristig
    </span>
    <span class="stat-pill" style="background:#f3f4f6;color:#374151">
      <i class="bi bi-building-x me-1"></i>{{ kritis.strukturelle_risiken | length }} Strukturelle Risiken
    </span>
  </div>
</div>

<div class="content-area">

  <!-- ── Lageübersicht ──────────────────────────────────────────────────── -->
  <div class="alert alert-danger border-danger mb-4 d-flex gap-3 align-items-start">
    <i class="bi bi-shield-exclamation fs-4 flex-shrink-0 mt-1"></i>
    <div>
      <strong>Akuter Handlungsbedarf für KRITIS-Betrieb.</strong>
      Das System weist {{ kritis.sofort | length }} kritische Schwachstellen auf, die bei einem
      Betreiber der höchsten KRITIS-Stufe einen sofortigen Betriebsstopp erfordern würden — darunter
      Remote Code Execution auf der Laufzeitumgebung sowie mehrere XML External Entity (XXE)-Lücken.
      Hinzu kommen {{ kritis.kurzfristig | length }} Schwachstellen mit hohem Risiko sowie
      {{ kritis.strukturelle_risiken | length }} strukturelle Sicherheitsrisiken, die einer
      umfassenderen Sanierung bedürfen.
    </div>
  </div>

  <!-- ── 1. CRITICAL — Sofortmaßnahmen ─────────────────────────────────── -->
  <section class="mb-5" id="sofort">
    <h4 class="section-title" style="color:#991b1b;border-color:#fca5a5">
      <i class="bi bi-exclamation-octagon-fill me-2"></i>1. CRITICAL — Sofortmaßnahmen
    </h4>
    <p class="small text-muted mb-3">
      Diese Schwachstellen müssen <strong>ohne Wartungsfenster</strong> behoben werden.
      Jede der folgenden CVEs stellt für einen KRITIS-Betreiber ein K.O.-Kriterium dar.
    </p>
    <div class="table-responsive">
      <table class="table table-sm table-bordered">
        <thead class="table-danger">
          <tr>
            <th style="width:14%">CVE</th>
            <th style="width:14%">Bibliothek</th>
            <th style="width:7%">Version</th>
            <th style="width:30%">Angriffsvektor</th>
            <th style="width:20%">Sofortmaßnahme</th>
            <th>KRITIS-Begründung</th>
          </tr>
        </thead>
        <tbody>
          {% for cve in kritis.sofort %}
          <tr class="table-danger">
            <td>
              <code class="fw-bold" style="color:#991b1b;background:#fee2e2">{{ cve.cve_id }}</code><br>
              <span class="badge" style="background:#dc2626;font-size:.65rem">{{ cve.nvd_schwere }}</span>
            </td>
            <td class="fw-semibold">{{ cve.bibliothek }}<br><span class="text-muted small font-monospace">{{ cve.version }}</span></td>
            <td class="text-center">
              <span class="badge bg-danger">{{ cve.nvd_schwere }}</span>
            </td>
            <td class="small">{{ cve.angriff }}</td>
            <td class="small">{{ cve.massnahme }}</td>
            <td class="small text-danger">{{ cve.kritis_begruendung }}</td>
          </tr>
          {% endfor %}
        </tbody>
      </table>
    </div>
  </section>

  <!-- ── 2. HIGH — Kurzfristig ──────────────────────────────────────────── -->
  <section class="mb-5" id="kurzfristig">
    <h4 class="section-title" style="color:#92400e;border-color:#fcd34d">
      <i class="bi bi-exclamation-triangle-fill me-2"></i>2. HIGH — Kurzfristig zu beheben
    </h4>
    <p class="small text-muted mb-3">
      Diese HIGH-CVEs erhöhen die Angriffsfläche signifikant. Im KRITIS-Kontext sind sie innerhalb
      von Wochen zu schließen — nicht innerhalb regulärer Patch-Zyklen.
    </p>
    <div class="table-responsive">
      <table class="table table-sm table-bordered">
        <thead class="table-warning">
          <tr>
            <th style="width:14%">CVE</th>
            <th style="width:14%">Bibliothek</th>
            <th style="width:7%">Version</th>
            <th style="width:35%">Angriffsvektor</th>
            <th>Maßnahme</th>
          </tr>
        </thead>
        <tbody>
          {% for cve in kritis.kurzfristig %}
          <tr class="table-warning">
            <td>
              <code class="fw-bold" style="color:#92400e;background:#fef3c7">{{ cve.cve_id }}</code><br>
              <span class="badge" style="background:#d97706;font-size:.65rem">{{ cve.nvd_schwere }}</span>
            </td>
            <td class="fw-semibold">{{ cve.bibliothek }}<br><span class="text-muted small font-monospace">{{ cve.version }}</span></td>
            <td class="text-center">
              <span class="badge bg-warning text-dark">{{ cve.nvd_schwere }}</span>
            </td>
            <td class="small">{{ cve.angriff }}</td>
            <td class="small">{{ cve.massnahme }}</td>
          </tr>
          {% endfor %}
        </tbody>
      </table>
    </div>
  </section>

  <!-- ── 3. Strukturelle Risiken ────────────────────────────────────────── -->
  <section class="mb-5" id="strukturell">
    <h4 class="section-title">
      <i class="bi bi-building-x me-2 text-secondary"></i>3. Strukturelle Sicherheitsrisiken
    </h4>
    <p class="small text-muted mb-3">
      Diese Risiken sind nicht durch einen einzelnen Patch behebbar — sie erfordern
      Architekturentscheidungen und mittelfristige Maßnahmen.
    </p>
    <div class="row g-3">
      {% for risiko in kritis.strukturelle_risiken %}
      <div class="col-md-6">
        <div class="card border {% if risiko.schwere == 'Kritisch' %}border-danger{% elif risiko.schwere == 'Hoch' %}border-warning{% else %}border-secondary{% endif %} h-100">
          <div class="card-body py-3">
            <div class="d-flex align-items-start gap-2 mb-2">
              <span class="badge {% if risiko.schwere == 'Kritisch' %}bg-danger{% elif risiko.schwere == 'Hoch' %}bg-warning text-dark{% else %}bg-secondary{% endif %} flex-shrink-0 mt-1" style="font-size:.7rem">
                {{ risiko.schwere }}
              </span>
              <h6 class="card-title mb-0" style="font-size:.9rem">{{ risiko.titel }}</h6>
            </div>
            <p class="card-text small text-muted mb-2">{{ risiko.beschreibung }}</p>
            <div class="d-flex align-items-center gap-2">
              <span class="badge bg-light text-dark border" style="font-size:.68rem"><i class="bi bi-bookmark me-1"></i>{{ risiko.norm }}</span>
              <span class="small text-muted"><i class="bi bi-wrench me-1"></i>{{ risiko.massnahme }}</span>
            </div>
          </div>
        </div>
      </div>
      {% endfor %}
    </div>
  </section>

  <!-- ── 4. Maßnahmenplan ───────────────────────────────────────────────── -->
  <section class="mb-5" id="massnahmenplan">
    <h4 class="section-title">
      <i class="bi bi-list-check me-2 text-primary"></i>4. Maßnahmenplan
    </h4>
    <div class="row g-3">
      {% for horizont in kritis.massnahmenplan %}
      <div class="col-md-6">
        <div class="card border-{{ horizont.farbe }} h-100">
          <div class="card-header bg-{{ horizont.farbe }} {% if horizont.farbe in ['danger', 'warning', 'primary'] %}{% if horizont.farbe == 'warning' %}text-dark{% else %}text-white{% endif %}{% else %}text-white{% endif %} py-2">
            <i class="{{ horizont.icon }} me-2"></i><strong>{{ horizont.horizont }}</strong>
            <span class="float-end small opacity-75">{{ horizont.beschreibung }}</span>
          </div>
          <ul class="list-group list-group-flush">
            {% for item in horizont['items'] %}
            <li class="list-group-item py-2 small d-flex gap-2">
              <i class="bi bi-check2-circle text-{{ horizont.farbe }} flex-shrink-0 mt-1"></i>
              {{ item }}
            </li>
            {% endfor %}
          </ul>
        </div>
      </div>
      {% endfor %}
    </div>
  </section>

  <!-- ── 5. Rechtsgrundlagen ────────────────────────────────────────────── -->
  <section class="mb-5" id="rechtsgrundlagen">
    <h4 class="section-title">
      <i class="bi bi-file-earmark-ruled me-2 text-primary"></i>5. Relevante Rechtsgrundlagen &amp; Normen
    </h4>
    <div class="table-responsive">
      <table class="table table-sm table-bordered">
        <thead class="table-light">
          <tr>
            <th style="width:18%">Norm / Gesetz</th>
            <th style="width:25%">Titel</th>
            <th>Relevanz für dieses System</th>
          </tr>
        </thead>
        <tbody>
          {% for norm in kritis.rechtsgrundlagen %}
          <tr>
            <td><code class="fw-semibold">{{ norm.norm }}</code></td>
            <td class="small fw-semibold">{{ norm.titel }}</td>
            <td class="small text-muted">{{ norm.relevanz }}</td>
          </tr>
          {% endfor %}
        </tbody>
      </table>
    </div>
  </section>

</div>
{% endblock %}
