{% extends "base.html.j2" %}

{% block title %}Modul: {{ module.module }} — OFBiz Docs{% endblock %}

{% macro class_card(cls) %}
<a href="{{ cls.id }}.html" class="text-decoration-none">
  <div class="class-card card p-3 h-100">
    <div class="d-flex justify-content-between align-items-start mb-1">
      <span class="fw-semibold text-dark" style="font-size:.9rem">{{ cls.name }}</span>
      {% set is_groovy = 'Groovy' in cls.type or cls.section == 'groovy' %}
      <span class="badge badge-type ms-1 {{ 'bg-success' if is_groovy else 'bg-primary' }}">
        {{ 'Groovy' if is_groovy else 'Java' }}
      </span>
    </div>
    {% if cls.package %}
    <div class="text-muted" style="font-size:.72rem;font-family:monospace">{{ cls.package }}</div>
    {% endif %}
    <p class="text-muted small mt-2 mb-0" style="font-size:.8rem">
      {{ cls.description[:120] }}{% if cls.description|length > 120 %}…{% endif %}
    </p>
    <div class="mt-2">
      {% if cls.is_group %}
        <span class="stat-pill"><i class="bi bi-collection me-1"></i>{{ cls.members | length }} Klassen</span>
      {% else %}
        <span class="stat-pill"><i class="bi bi-lightning me-1"></i>{{ cls.methods | length }} Methoden</span>
      {% endif %}
    </div>
  </div>
</a>
{% endmacro %}

{% block content %}
<div class="page-header">
  <nav aria-label="breadcrumb">
    <ol class="breadcrumb mb-2">
      <li class="breadcrumb-item"><a href="{{ root }}index.html">Module</a></li>
      <li class="breadcrumb-item active">{{ module.module }}</li>
    </ol>
  </nav>
  <h1><i class="bi bi-box me-2 text-primary"></i>{{ module.module }}</h1>
  <div class="d-flex gap-2 mt-2">
    <span class="stat-pill"><i class="bi bi-layers me-1"></i>{{ module.stats.classes }} Klassen</span>
    <span class="stat-pill"><i class="bi bi-lightning me-1"></i>{{ module.stats.methods }} public Methoden</span>
  </div>
</div>

<div class="content-area">

  <!-- Overview -->
  <section class="mb-4">
    <h5 class="text-muted text-uppercase" style="font-size:.75rem;letter-spacing:.08em">Überblick</h5>
    <p>{{ module.overview }}</p>
  </section>

  <!-- Submodules -->
  {% if module.submodules %}
  <section class="mb-4">
    <h5 class="text-muted text-uppercase" style="font-size:.75rem;letter-spacing:.08em">Submodule</h5>
    <div class="table-responsive">
      <table class="table table-sm table-bordered">
        <thead class="table-light">
          <tr><th>Paket</th><th>Beschreibung</th></tr>
        </thead>
        <tbody>
          {% for sm in module.submodules %}
          <tr>
            <td><code>{{ sm.name }}</code></td>
            <td class="text-muted small">{{ sm.description }}</td>
          </tr>
          {% endfor %}
        </tbody>
      </table>
    </div>
  </section>
  {% endif %}

  <!-- Tab navigation -->
  {% set java_classes   = module.classes | selectattr('section', 'equalto', 'java')   | list %}
  {% set groovy_classes = module.classes | selectattr('section', 'equalto', 'groovy') | list %}
  {% set test_classes   = module.classes | selectattr('section', 'equalto', 'test')   | list %}

  <ul class="nav nav-tabs mb-4" id="classTabs" role="tablist">
    {% if java_classes %}
    <li class="nav-item" role="presentation">
      <button class="nav-link active" id="tab-java" data-bs-toggle="tab"
              data-bs-target="#pane-java" type="button">
        <i class="bi bi-filetype-java me-1"></i>Java
        <span class="badge bg-primary ms-1">{{ java_classes | length }}</span>
      </button>
    </li>
    {% endif %}
    {% if groovy_classes %}
    <li class="nav-item" role="presentation">
      <button class="nav-link {% if not java_classes %}active{% endif %}"
              id="tab-groovy" data-bs-toggle="tab"
              data-bs-target="#pane-groovy" type="button">
        <i class="bi bi-braces me-1"></i>Groovy
        <span class="badge bg-success ms-1">{{ groovy_classes | length }}</span>
      </button>
    </li>
    {% endif %}
    {% if test_classes %}
    <li class="nav-item" role="presentation">
      <button class="nav-link {% if not java_classes and not groovy_classes %}active{% endif %}"
              id="tab-test" data-bs-toggle="tab"
              data-bs-target="#pane-test" type="button">
        <i class="bi bi-check2-circle me-1"></i>Tests
        <span class="badge bg-secondary ms-1">{{ test_classes | length }}</span>
      </button>
    </li>
    {% endif %}
  </ul>

  <div class="tab-content">

    {% if java_classes %}
    <div class="tab-pane fade show active" id="pane-java" role="tabpanel">
      <div class="row g-2">
        {% for cls in java_classes %}
        <div class="col-md-6 col-xl-4">{{ class_card(cls) }}</div>
        {% endfor %}
      </div>
    </div>
    {% endif %}

    {% if groovy_classes %}
    <div class="tab-pane fade {% if not java_classes %}show active{% endif %}"
         id="pane-groovy" role="tabpanel">
      <div class="row g-2">
        {% for cls in groovy_classes %}
        <div class="col-md-6 col-xl-4">{{ class_card(cls) }}</div>
        {% endfor %}
      </div>
    </div>
    {% endif %}

    {% if test_classes %}
    <div class="tab-pane fade {% if not java_classes and not groovy_classes %}show active{% endif %}"
         id="pane-test" role="tabpanel">
      <div class="row g-2">
        {% for cls in test_classes %}
        <div class="col-md-6 col-xl-4">{{ class_card(cls) }}</div>
        {% endfor %}
      </div>
    </div>
    {% endif %}

  </div>

</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
{% endblock %}
