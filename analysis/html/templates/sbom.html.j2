{% extends "base.html.j2" %}
{% block title %}SBOM — Externe Abhängigkeiten{% endblock %}

{% block content %}
<div class="page-header">
  <nav aria-label="breadcrumb">
    <ol class="breadcrumb mb-2">
      <li class="breadcrumb-item"><a href="{{ root }}index.html">Übersicht</a></li>
      <li class="breadcrumb-item active">SBOM</li>
    </ol>
  </nav>
  <h1><i class="bi bi-box-seam me-2 text-primary"></i>Software Bill of Materials</h1>
  {% set vuln_count = libraries | sum(attribute='vulns', start=[]) | list | length %}
  {% set affected_count = libraries | selectattr('vulns') | list | length %}
  <p class="text-muted mb-0 mt-1 small">
    {{ libraries | length }} externe Abhängigkeiten &middot;
    {% if vuln_count > 0 %}
    <span class="text-danger fw-semibold"><i class="bi bi-exclamation-triangle me-1"></i>{{ vuln_count }} Schwachstellen in {{ affected_count }} Libraries</span> &middot;
    {% endif %}
    Quelle: <code>decompiled/build.gradle</code> &middot; Daten: <a href="https://osv.dev" target="_blank">OSV</a>
  </p>
</div>

<div class="content-area">

{% set categories = libraries | map(attribute='category') | unique | sort | list %}
{% for cat in categories %}
{% set cat_libs = libraries | selectattr('category', 'equalto', cat) | list %}
<section class="mb-5">
  <h4 class="section-title">{{ cat }}
    <span class="badge bg-secondary ms-2" style="font-size:.7rem;font-weight:500;vertical-align:middle">{{ cat_libs | length }}</span>
  </h4>
  <div class="table-responsive">
    <table class="table table-sm table-bordered table-hover">
      <thead class="table-light">
        <tr>
          <th style="width:18%">Artifact</th>
          <th style="width:22%">Group</th>
          <th style="width:8%">Version</th>
          <th style="width:28%">Beschreibung</th>
          <th>Schwachstellen</th>
        </tr>
      </thead>
      <tbody>
        {% for lib in cat_libs %}
        {% set has_vulns = lib.vulns is defined and lib.vulns | length > 0 %}
        <tr {% if has_vulns %}class="table-danger"{% elif lib.scope == 'test' %}class="table-secondary"{% endif %}>
          <td class="fw-semibold">{{ lib.artifact }}</td>
          <td class="text-muted small font-monospace">{{ lib.group }}</td>
          <td><span class="badge bg-light text-dark border" style="font-size:.75rem;font-family:monospace">{{ lib.version }}</span></td>
          <td class="small text-muted">{{ lib.description }}</td>
          <td class="small">
            {% if has_vulns %}
            {% for v in lib.vulns %}
            <div class="mb-2">
              <div class="d-flex align-items-center gap-2 mb-1">
                {% if v.cves %}
                <a href="https://nvd.nist.gov/vuln/detail/{{ v.cves[0] }}" target="_blank" rel="noopener"
                   style="font-size:.75rem;font-family:monospace">{{ v.cves[0] }}</a>
                {% else %}
                <a href="https://github.com/advisories/{{ v.id }}" target="_blank" rel="noopener"
                   style="font-size:.75rem;font-family:monospace">{{ v.id }}</a>
                {% endif %}
                {% if v.severity %}
                <span class="badge
                  {% if v.severity == 'CRITICAL' %}bg-danger
                  {% elif v.severity == 'HIGH' %}bg-danger
                  {% elif v.severity in ('MODERATE', 'MEDIUM') %}bg-warning text-dark
                  {% else %}bg-secondary{% endif %}"
                  style="font-size:.72rem">{{ v.severity }}</span>
                {% endif %}
                {% if v.cwe_ids %}
                <span class="text-muted" style="font-size:.7rem">{{ v.cwe_ids | join(', ') }}</span>
                {% endif %}
              </div>
              {% if v.summary %}
              <div class="text-dark" style="font-size:.8rem">{{ v.summary }}</div>
              {% endif %}
            </div>
            {% endfor %}
            {% else %}
            <span class="text-muted">Keine bekannten Schwachstellen</span>
            {% endif %}
          </td>
        </tr>
        {% endfor %}
      </tbody>
    </table>
  </div>
</section>
{% endfor %}

</div>
{% endblock %}
