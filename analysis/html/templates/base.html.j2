<!DOCTYPE html>
<html lang="de">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>{% block title %}OFBiz Architekturdokumentation{% endblock %}</title>
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css">
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
  <style>
    :root {
      --sidebar-width: 220px;
      --accent: #0d6efd;
    }
    body { font-size: .925rem; }
    #sidebar {
      width: var(--sidebar-width);
      min-height: 100vh;
      background: #1e2430;
      color: #c9d1d9;
      position: fixed;
      top: 0; left: 0;
      overflow-y: auto;
      z-index: 100;
    }
    #sidebar .sidebar-brand {
      font-size: 1rem;
      font-weight: 700;
      color: #fff;
      padding: 1.25rem 1rem .75rem;
      display: block;
      text-decoration: none;
      border-bottom: 1px solid #2d3748;
    }
    #sidebar .nav-link {
      color: #a0aec0;
      padding: .35rem 1rem;
      font-size: .85rem;
      border-radius: 0;
    }
    #sidebar .nav-link:hover, #sidebar .nav-link.active {
      color: #fff;
      background: #2d3748;
    }
    #sidebar .nav-section {
      font-size: .7rem;
      text-transform: uppercase;
      letter-spacing: .08em;
      color: #4a5568;
      padding: .75rem 1rem .25rem;
    }
    #main {
      margin-left: var(--sidebar-width);
      min-height: 100vh;
    }
    .page-header {
      background: #f8f9fa;
      border-bottom: 1px solid #dee2e6;
      padding: 1.5rem 2rem;
    }
    .page-header h1 { font-size: 1.5rem; margin: 0; }
    .content-area { padding: 2rem; }
    .badge-type {
      font-size: .7rem;
      font-weight: 500;
    }
    .method-table th { white-space: nowrap; }
    .method-sig {
      font-family: SFMono-Regular, Menlo, monospace;
      font-size: .82rem;
      color: #0550ae;
    }
    .class-card {
      border: 1px solid #e2e8f0;
      border-radius: 8px;
      transition: box-shadow .15s;
    }
    .class-card:hover { box-shadow: 0 2px 8px rgba(0,0,0,.1); }
    .class-card .card-title { font-size: .95rem; }
    .breadcrumb { font-size: .82rem; }
    .stat-pill {
      background: #eef2ff;
      color: #3730a3;
      border-radius: 20px;
      padding: .15rem .65rem;
      font-size: .78rem;
      font-weight: 600;
    }
    code { color: #0550ae; background: #f0f4ff; padding: .1em .35em; border-radius: 3px; }
  </style>
</head>
<body>

<!-- Sidebar -->
<nav id="sidebar">
  <a class="sidebar-brand" href="{{ root }}index.html">
    <i class="bi bi-diagram-3 me-2"></i>OFBiz Docs
  </a>
  <div class="nav-section">Analyse</div>
  <ul class="nav flex-column mb-2">
    <li class="nav-item">
      <a class="nav-link {% if active_module == '__sbom__' %}active{% endif %}"
         href="{{ root }}sbom.html">
        <i class="bi bi-box-seam me-1"></i>SBOM
        <span class="stat-pill ms-1">79</span>
      </a>
    </li>
  </ul>
  <div class="nav-section">Module</div>
  <ul class="nav flex-column">
    {% for mod in modules %}
    <li class="nav-item">
      <a class="nav-link {% if active_module == mod.id %}active{% endif %}"
         href="{{ root }}{{ mod.id }}/index.html">
        <i class="bi bi-box me-1"></i>{{ mod.name }}
        <span class="stat-pill ms-1">{{ mod.stats.classes }}</span>
      </a>
    </li>
    {% endfor %}
  </ul>
</nav>

<!-- Main -->
<div id="main">
  {% block content %}{% endblock %}
</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/mermaid@11/dist/mermaid.min.js"></script>
<script>mermaid.initialize({startOnLoad:true, theme:'default', flowchart:{curve:'basis'}});</script>
</body>
</html>
